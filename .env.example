# === Backend (Render) ===
PORT=8787
JWT_SECRET=replace-with-a-strong-random-secret
GEMINI_API_KEY=

# MongoDB Atlas connection string
# e.g. mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/ecofeast
MONGODB_URI=

# Comma-separated list of allowed frontend origins (CORS)
# For Vercel deployment, set this to your Vercel URL e.g. https://ecofeast.vercel.app
FRONTEND_ORIGIN=http://localhost:5173

# === Frontend (Vercel) ===
# For local dev with proxy, use /api
# For production, set to the full Render backend URL e.g. https://ecofeast-api.onrender.com/api
VITE_API_BASE_URL=/api
